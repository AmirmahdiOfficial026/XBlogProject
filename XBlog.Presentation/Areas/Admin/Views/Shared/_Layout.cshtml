<!doctype html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] | XBLog</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" />
    <link rel="stylesheet" href="~/vendor/font-awesome/css/font-awesome.min.css" />
    <link rel="stylesheet" href="~/css/style.default.css" id="theme-stylesheet">
</head>

<body>

  
    <header class="header">
        <nav class="navbar navbar-expand-lg">
            <div class="container">
                <div class="navbar-header d-flex align-items-center justify-content-between">
                    <div class="d-block d-lg-none">
                        <div class="btn-group">
                            <a asp-area="" asp-controller="Account" asp-action="EditUser">
                                <i class="fa fa-2x fa-user-circle text-secondary"></i>
                            </a>
                        </div>
                    </div>
                    <a asp-area="" asp-controller="Home" asp-action="Index" class="m-auto navbar-brand">
                        <img src="~/img/WeblogLogo.png" alt="XBlog" title="XBlog" width="50" height="50">
                    </a>
                    <button type="button" data-toggle="collapse" data-target="#navbarcollapse" aria-controls="navbarcollapse"
                            aria-expanded="false" aria-label="Toggle navigation" class="navbar-toggler">
                        <span></span><span></span><span></span>
                    </button>
                </div>
                <div id="navbarcollapse" class="collapse navbar-collapse">
                    <ul class="navbar-nav">
                        <li class="nav-item">
                            <a class="nav-link"
                               asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        <li>
                            <a class="nav-link"
                               asp-area="Admin" asp-controller="ArticleCategory" asp-action="Index">Article Category Management</a>
                        </li>
                        <li>
                            <a class="nav-link"
                               asp-area="Admin" asp-controller="Article" asp-action="Index">Article Management</a>
                        </li>
                        <li>
                            <a class="nav-link"
                               asp-area="Admin" asp-controller="Comment" asp-action="Index">Comment Management</a>
                        </li>
                        <li>
                            <a class="nav-link"
                               asp-area="Admin" asp-controller="UserManager" asp-action="UsersList">User Manager</a>
                        </li>
                        <li>
                            <a class="nav-link "
                               asp-area="Admin" asp-controller="Home" asp-action="Index">Admin Panel</a>
                        </li>
                    </ul>
                </div>
                <div class="d-none d-lg-block">
                    <div class="btn-group">
                        <a asp-area="" asp-controller="Account" asp-action="EditUser">
                            <i class="fa fa-2x fa-user-circle text-secondary"></i>
                        </a>
                    </div>
                </div>
            </div>
        </nav>
    </header>
    <div class="container my-3">
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert" id="successAlert">
                <i class="bi bi-check-circle-fill"></i> @TempData["Success"]
            </div>
        }

        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert" id="errorAlert">
                <i class="bi bi-exclamation-triangle-fill"></i> @TempData["Error"]
            </div>
        }
    </div>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>


    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - Onion.Presentation -
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/front.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
</body>

</html>