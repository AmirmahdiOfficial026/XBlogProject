@using XBlog.Infrastructure.Identity
@model List<ApplicationUser>

<div class="card">
    <div class="card-header">
        <h3 class="float-left">User Manager</h3>
        <div class="float-right">
            <a href="Create.html" class="btn btn-success">Add New</a>
        </div>
    </div>
    <div class="card-body">
        <div class="TableRespons">
            <table class="table">
                <tr>
                    <th>ID:</th>
                    <th>Username:</th>
                    <th>Email:</th>
                    <th>Operation:</th>
                </tr>
                @foreach (var user in Model)
                {
                    <tr>
                        <td>@user.Id</td>
                        <td>@user.UserName</td>
                        <td>@user.Email</td>
                        <td>
                            <a asp-area="Admin" asp-controller="UserManager" asp-action="Index" asp-route-id="@user.Id"
                               class="btn btn-warning float-left mr-3">Edit</a>
                        </td>
                    </tr>
                }
            </table>
        </div>
    </div>
</div>
