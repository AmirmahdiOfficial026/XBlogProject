@using XBlog.Application.Dto
@model ArticleUpdateDto
@{
    ViewData["Title"] = "Edit Article";
}


<div class="card">
    <div class="card-header">
        <h2>Edit Article : @Model.Title</h2>
    </div>
    <div class="card-body">
        <div class="row">
            <div class="col-md-12">
                <form method="post" asp-area="Admin" asp-controller="Article" asp-action="Edit" enctype="multipart/form-data">
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                    <input type="hidden" asp-for="Id" />
                    <div class="col-md-6 col-sm-12">
                        <div class="form-group">
                            <label asp-for="Title" class="control-label">Title:</label>
                            <input asp-for="Title" type="text" class="form-control" autocomplete="off" />
                            <span asp-validation-for="Title" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="col-md-6 col-sm-12">
                        <div class="form-group">
                            <label asp-for="ShortDescription" class="control-label">ShortDescription:</label>
                            <textarea asp-for="ShortDescription" class="form-control" rows="3"></textarea>
                            <span asp-validation-for="ShortDescription" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="col-md-6 col-sm-12">
                        <div class="form-group">
                            <label asp-for="Image" class="control-label">Image:</label>
                            <input asp-for="Image" type="file" class="form-control-file" autocomplete="off" />
                            <input asp-for="ImageUrl" type="hidden" />
                            <span asp-validation-for="Image" class="text-danger"></span>
                        </div>
                    </div>


                    <div class="col-md-6 col-sm-12">
                        <div class="form-group">
                            <label asp-for="Content" class="control-label">Content:</label>
                            <textarea asp-for="Content" class="form-control" rows="5"></textarea>
                            <span asp-validation-for="Content" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="col-md-6 col-sm-12">
                        <div class="form-group">
                            <label asp-for="ArticleCategoryId" class="control-label">Article Category:</label>
                            <select asp-for="ArticleCategoryId" asp-items="@ViewBag.Categories" class="form-control">
                                <option value="0">-- Select Category --</option>
                            </select>
                            <span asp-validation-for="ArticleCategoryId" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="form-group">
                        <input type="submit" value="Edit" class="btn btn-warning" />
                        <a asp-area="Admin" asp-controller="Article" asp-action="Index" class="btn btn-dark">Back to list</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>