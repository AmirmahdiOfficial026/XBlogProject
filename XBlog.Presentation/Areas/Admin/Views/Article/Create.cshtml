@using XBlog.Presentation.Areas.Admin.Models
@model ArticleCreateModelView
@{
    ViewData["Title"] = "Create Article";
}
<div class="card">
    <div class="card-header">
        <h2>Create New Article</h2>
    </div>
    <div class="card-body">
        <div class="row">
            <div class="col-md-12">
                <form method="post" asp-area="Admin" asp-controller="Article" asp-action="Create" enctype="multipart/form-data">
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                    <div class="col-md-6 col-sm-12">
                        <div class="form-group">
                            <label asp-for="Article.Title" class="control-label">Title:</label>
                            <input asp-for="Article.Title" type="text" class="form-control" autocomplete="off" />
                            <span asp-validation-for="Article.Title" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="col-md-6 col-sm-12">
                        <div class="form-group">
                            <label asp-for="Article.ShortDescription" class="control-label">ShortDescription:</label>
                            <textarea asp-for="Article.ShortDescription" class="form-control" rows="3"></textarea>
                            <span asp-validation-for="Article.ShortDescription" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="col-md-6 col-sm-12">
                        <div class="form-group">
                            <label asp-for="Article.Image" class="control-label">Image:</label>
                            <input asp-for="Article.Image" type="file" class="form-control-file" autocomplete="off" />
                            <span asp-validation-for="Article.Image" class="text-danger"></span>
                        </div>
                    </div>
                    <div class="col-md-6 col-sm-12">
                        <div class="form-group">
                            <label asp-for="Article.Content" class="control-label">Content:</label>
                            <textarea asp-for="Article.Content" class="form-control" rows="5"></textarea>
                            <span asp-validation-for="Article.Content" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="col-md-6 col-sm-12">
                        <div class="form-group">
                            <label asp-for="Article.ArticleCategoryId" class="control-label">Article Category:</label>
                            <select asp-for="Article.ArticleCategoryId" asp-items="@Model.categories" class="form-control">
                                <option value="0">--Select Article Category--</option>
                            </select>
                            <span asp-validation-for="Article.ArticleCategoryId" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="form-group">
                        <input type="submit" value="Create" class="btn btn-success" />
                        <a asp-area="Admin" asp-controller="Article" asp-action="Index" class="btn btn-dark">Back to list</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
