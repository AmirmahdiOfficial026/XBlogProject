@using XBlog.Application.Dto
@model IEnumerable<ArticleDto>
@{
    ViewData["Title"] = "Article Management";
}
<div class="card">
    <div class="card-header">
        <h3 class="float-left">Article List</h3>
        <div class="float-right">
            <a asp-area="Admin" asp-controller="Article" asp-action="Create" class="btn btn-success">Add New</a>
        </div>
    </div>
    <div class="card-body">
        <div class="TableRespons">
            <table class="table">

                <tr>
                    <th>ID:</th>
                    <th>Title:</th>
                    <th>Article Category:</th>
                    <th>Status:</th>
                    <th>Creation Date:</th>
                    <th>Operation:</th>
                </tr>

                @foreach (var article in Model)
                {
                    <tr>
                        <td>@article.Id</td>
                        <td>@article.Title</td>
                        <td>@article.CategoryTitle</td>
                        <td>
                            @if (article.IsDeleted)
                            {
                                <i class="fa fa-2x fa-close text-danger"></i>
                            }
                            @if (!article.IsDeleted)
                            {
                                <i class="fa fa-2x fa-check text-success"></i>
                            }
                        </td>
                        <td>@article.CreationDate</td>
                        <td>
                            <a method="post" asp-area="Admin" asp-controller="Article" asp-action="Edit" asp-route-Id="@article.Id" class="btn btn-warning float-left mr-3 my-2">Edit</a>
                            @if (article.IsDeleted)
                            {
                                <form class="my-2 my-md-0 float-left" method="post" asp-area="Admin" asp-controller="Article" asp-action="Active">
                                    <button class="btn btn-success">Activate</button>
                                    <input type="hidden" name="id" value="@article.Id" />
                                </form>
                            }
                            else
                            {
                                <form class="my-2 my-md-0 float-left" method="post" asp-area="Admin" asp-controller="Article" asp-action="Remove">
                                    <button class="btn btn-danger">Remove</button>
                                    <input type="hidden" name="id" value="@article.Id" />
                                </form>
                            }
                        </td>
                    </tr>
                }

            </table>
        </div>
    </div>
</div>
