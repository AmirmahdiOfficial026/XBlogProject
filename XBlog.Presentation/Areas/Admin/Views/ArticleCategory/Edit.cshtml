@using XBlog.Application.Dto
@model ArticleCategoryUpdateDto
@{
    ViewData["Title"] = "Edit Article Category";
}

<div class="card">
    <div class="card-header">
        <h2>Edit Article Category: @Model.Title</h2>
    </div>
    <div class="card-body">
        <div class="row">
            <div class="col-md-12">
                <form method="post" asp-area="Admin" asp-controller="ArticleCategory" asp-action="Edit">
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                    <input type="hidden" asp-for="Id" />
                    <div class="col-md-6 col-sm-12">
                        <div class="form-group">
                            <label asp-for="Title">Title:</label>
                            <input asp-for="Title" type="text" class="form-control" autocomplete="off" />
                            <span asp-validation-for="Title" class="text-danger"></span>
                        </div>
                    </div>
                    <div class="form-group">
                        <input type="submit" value="Edit" class="btn btn-warning" />
                        <a asp-area="Admin" asp-controller="ArticleCategory" asp-action="Index"
                           class="btn btn-dark">Back to list</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>