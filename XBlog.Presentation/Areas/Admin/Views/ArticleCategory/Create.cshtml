@using XBlog.Application.Dto
@model ArticleCategoryCreateDto
@{
    ViewData["Title"] = "Create Article Category";
}
<div class="card">
    <div class="card-header">
        <h2>Create New Article Category</h2>
    </div>
    <div class="card-body">
        <div class="row">
            <div class="col-md-12">
                <form method="post" asp-area="Admin" asp-controller="ArticleCategory" asp-action="Create">
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                    <div class="col-md-6 col-sm-12">
                        <div class="form-group">
                            <label asp-for="Title">Title:</label>
                            <input asp-for="Title" class="form-control" type="text" autocomplete="off" />
                            <span asp-validation-for="Title" class="text-danger"></span>
                        </div>
                    </div>
                    <div class="form-group">
                        <input type="submit" value="create" class="btn btn-success" />
                        <a asp-area="Admin" asp-controller="ArticleCategory" asp-action="Index"
                        class="btn btn-dark">Back to List</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>