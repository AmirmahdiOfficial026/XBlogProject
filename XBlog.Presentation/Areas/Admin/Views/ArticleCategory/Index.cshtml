@using XBlog.Presentation.Areas.Admin.Models
@model IEnumerable<ArticleCategoryModelView>
@{
    ViewData["Title"] = "Article Category Management";
}
<div class="card">
    <div class="card-header">
        <div class="row">
            <div class="col-12">
                <h3 class="float-left">Article Category list:</h3>
                <div class="float-right">
                    <a asp-area="Admin" asp-controller="ArticleCategory" asp-action="Create" class="btn btn-success">Add new</a>
                </div>
            </div>
        </div>
    </div>
    <div class="card-body">
        <div class="TableRespons">
            <table class="table">
                <tr>
                    <th>ID:</th>
                    <th>Title:</th>
                    <th>Status:</th>
                    <th>Creation Date:</th>
                    <th>Operation:</th>
                </tr>
                @foreach (var articleCategory in Model)
                {

                    <tr>
                        <td>@articleCategory.Id</td>
                        <td>@articleCategory.Title</td>
                        <td>
                            @if (articleCategory.IsDeleted)
                            {
                                <i class="fa fa-2x fa-close text-danger"></i>
                            }
                            @if (!articleCategory.IsDeleted)
                            {
                                <i class="fa fa-2x fa-check text-success"></i>
                            }
                        </td>
                        <td>@articleCategory.CreationDate</td>
                        <td>
                            <a asp-area="Admin" asp-controller="ArticleCategory" asp-action="Edit"
                               asp-route-Id="@articleCategory.Id" class="btn btn-warning float-left mr-3">Rename</a>
                            @if (articleCategory.IsDeleted)
                            {
                                <form class="float-left mt-3 mt-md-0" asp-area="Admin" asp-controller="ArticleCategory" asp-action="Active" method="post">
                                    <button class="btn btn-success">Activate</button>
                                    <input type="hidden" name="id" value="@articleCategory.Id" />
                                </form>
                            }
                            else
                            {
                                <form class="float-left mt-3 mt-md-0" asp-area="Admin" asp-controller="ArticleCategory" asp-action="Remove" method="post">
                                    <button class="btn btn-danger">Remove</button>
                                    <input type="hidden" name="id" value="@articleCategory.Id" />
                                </form>
                            }
                        </td>
                    </tr>

                }
            </table>
        </div>
    </div>
</div>