@model UpdateUserAccountModelView
@{
    ViewData["Title"] = "User Account";
}
<div class="card w-75 m-auto">
    <div class="card-header text-center">
        <h2>User Account</h2>
    </div>
    <div class="card-body">
        <div class="">
            <form asp-area="" asp-controller="Account" asp-action="EditUser">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                <input type="hidden" asp-for="Id" />
                <div>
                    <label asp-for="Username">Username</label>
                    <input asp-for="Username" type="text" class="form-control" autocomplete="off">
                    <span asp-validation-for="Username" class="text-danger"></span>
                </div>
                <div>
                    <label asp-for="Email">Email</label>
                    <input asp-for="Email" type="text" class="form-control" autocomplete="off">
                    <span asp-validation-for="Email"></span>
                </div>
                <div>
                    <label asp-for="Password">Password</label>
                    <input asp-for="Password" type="password" class="form-control" autocomplete="off">
                    <span asp-validation-for="Password" class="text-danger"></span>
                </div>
                <div>
                    <label asp-for="RePassword">Comfirm Password</label>
                    <input asp-for="RePassword" type="password" class="form-control" autocomplete="off">
                    <span asp-validation-for="RePassword" class="text-danger"></span>
                </div>
                <div>
                    <button type="submit" class="btn btn-warning">Edit</button>
                    <a asp-area="" asp-controller="Account" asp-action="SignOut"
                       class="btn btn-danger">Sign Out</a>
                </div>
            </form>
        </div>
    </div>
</div>