@model SignInViewModel
@{
    ViewData["Title"] = "SignIn";
    ViewData["HideFooter"] = true;
}


<div class="card w-50 m-auto">
    <div class="card-header text-center">
        <h2>Sign In</h2>
    </div>
    <div class="card-body">
        <div class="">
            <form asp-area="" asp-controller="Account" asp-action="SignIn">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                <div>
                    <label asp-for="@Model.Username">Username</label>
                    <input asp-for="@Model.Username" type="text" class="form-control" autocomplete="off">
                    <span asp-validation-for="@Model.Username" class="text-danger"></span>
                </div>
                <div>
                    <label asp-for="@Model.Email">Email</label>
                    <input asp-for="@Model.Email" type="text" class="form-control" autocomplete="off">
                    <span asp-validation-for="@Model.Email" class="text-danger"></span>
                </div>
                <div>
                    <label asp-for="@Model.Password">Password</label>
                    <input asp-for="@Model.Password" type="password" class="form-control" autocomplete="off">
                    <span asp-validation-for="@Model.Password" class="text-danger"></span>
                </div>
                <div>
                    <label asp-for="@Model.RePassword">Comfirm Password</label>
                    <input asp-for="@Model.RePassword" type="password" class="form-control" autocomplete="off">
                    <span asp-validation-for="@Model.RePassword" class="text-danger"></span>
                </div>
                <div>
                    <button type="submit" class="btn btn-primary">Sign In</button>
                </div>
            </form>
        </div>
    </div>
</div>