@using XBlog.Application.Dto
@model List<PopularArticleDto>

@if (Model != null && Model.Any())
{
    @foreach (var article in Model)
    {
        <a asp-area="" asp-controller="ArticleDetails" asp-action="ArticleDetail" asp-route-id="@article.Id" class="d-inline-block w-100">
            <div class="post d-flex align-items-center">
                <div class="image">
                    <img src="@article.Image" alt="@article.Title" title="@article.Title" class="img-fluid">
                </div>
                <div class="title">
                    <strong>@article.Title</strong>
                    <span class="date last-meta">
                        @article.CreationDate.Month , @article.CreationDate.Day
                        @article.CreationDate.Year
                    </span>
                </div>
            </div>
        </a>
    }
}