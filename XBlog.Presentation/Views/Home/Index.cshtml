@using XBlog.Application.Dto
@model IEnumerable<ArticleDto>
@{
    ViewData["Title"] = "Home";
    int totalPages = (int)Math.Ceiling((double)ViewBag.TotalCount / 10);
    var currentPage = (int)ViewBag.CurrentPage;
    var prevPage = currentPage - 1;
    var nextPage = currentPage + 1;
    var groupSize = 3;
    var startPage = Math.Max(1, currentPage - 1);
    var endPage = Math.Min(totalPages, currentPage + 1);
    if (currentPage == 1)
    {
        startPage = 1;
        endPage = Math.Min(3, totalPages);
    }
    else if (currentPage == totalPages)
    {
        startPage = Math.Max(1, totalPages - 2);
        endPage = totalPages;
    }
    else if (totalPages == 2)
    {
        startPage = 1;
        endPage = 2;
    }
}

<div class="container">
    <div class="row">

        @foreach (var article in Model)
        {
            <div class="post col-lg-6">
                <div class="row">
                    <div class="post-thumbnail col-12 col-md-8 col-lg-12">
                        <a asp-area="" asp-controller="ArticleDetails" asp-action="ArticleDetail" asp-route-Id="@article.Id" class="w-100">
                            <img src="@article.Image" alt="@article.Title" title="@article.Title" class="img-fluid w-100" style="height: 380px">
                        </a>
                    </div>
                    <div class="post-details col-12 col-md-4 col-lg-12">
                        <div class="post-meta d-flex justify-content-between">
                            <div class="date meta-last">@article.CreationDate</div>
                            <div class="category">
                                <a asp-area="" asp-controller="ArticleDetails" asp-action="ArticleDetail" asp-route-Id="@article.Id">@article.CategoryTitle</a>
                            </div>
                        </div>
                        <a asp-area="" asp-controller="ArticleDetails" asp-action="ArticleDetail" asp-route-Id="@article.Id">
                            <h3 class="h4">@article.Title</h3>
                        </a>
                        <p class="text-muted">
                            @article.ShortDescription
                        </p>
                        <footer class="post-footer d-flex align-items-center">
                            <div class="comments meta-last"><i class="icon-comment"></i>@article.CommentCount</div>
                        </footer>
                    </div>
                </div>
            </div>
        }
        <div class="col-12 d-flex justify-content-center">

            <nav aria-label="Page navigation example">
                <ul class="pagination">
                    <li class="page-item">
                        <a class="page-link" asp-action="Index"
                           asp-route-page="1">First</a>
                    </li>

                    @for (int i = startPage; i <= endPage; i++)
                    {
                        <li class="page-item @(i == currentPage ? "active" : "")">
                            <a class="page-link @(i == currentPage ? "btn-dark" : "btn-outline-dark")" asp-action="Index"
                               asp-route-page="@i" aria-current="page">@i</a>
                        </li>
                    }
                    <li class="page-item">
                        <a class="page-link btn-primary" asp-action="Index"
                           asp-route-page="@totalPages">Last</a>
                    </li>
                </ul>
            </nav>
        </div>
    </div>
</div>
